# ─────────────────────────────────────────────────────────────
# AION AI Business OS — Environment Variables
# ─────────────────────────────────────────────────────────────
# Para desarrollo local: copiar como .env.local
# Para producción: configurar en Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ─── Client-side (prefijo VITE_ = expuesto al browser) ─────
# Supabase (autenticación)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# (Opcional) Token de autenticación para el AI proxy
# VITE_APP_TOKEN=tu-token-secreto

# (Opcional) URL del proxy de IA (default: /api/ai)
# VITE_PROXY_URL=/api/ai

# ─── Server-side (Vercel Edge Function) ────────────────────
# OpenRouter API key (openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# (Opcional) Token compartido frontend ↔ proxy (debe coincidir con VITE_APP_TOKEN)
# AION_APP_TOKEN=tu-token-secreto
